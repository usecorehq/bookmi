NODE_ENV=development
APP_ENV=dev
PORT=4000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────
# Local self-hosted: http://localhost:8000
# Cloud:            https://<project-ref>.supabase.co
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# HS256 secret from Supabase → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=

# Postgres connection.
# Local:            postgres://postgres:<pw>@localhost:54322/postgres
# Cloud (direct):   postgres://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
# Cloud (pooled):   postgres://postgres.<ref>:<pw>@<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=
# Optional — only needed when the GoTrue Send Email hook is enabled.
# Must match GOTRUE_HOOK_SEND_EMAIL_SECRETS in your docker-compose.yml (self-hosted)
# or the secret generated in Supabase Dashboard → Auth → Hooks (cloud).
# Format: v1,whsec_<base64-secret>
SUPABASE_EMAIL_HOOK_SECRET=

# ── Monnify ───────────────────────────────────────────────────
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WEBHOOK_SECRET=
# Source-of-funds account for outbound transfers (refunds, host payouts).
# Sandbox: the wallet account number listed under "Wallet as Source" in the
# Monnify dashboard once you enable it. Prod: your operations wallet.
MONNIFY_DISBURSEMENT_WALLET=
# Rollout flag for the real reserved-account API (dedicated virtual accounts
# per host). Defaults to false — HostWalletService keeps fabricating a mock
# reserved account until this is set to true after a sandbox smoke test.
MONNIFY_USE_RESERVED_ACCOUNT_API=false
# Optional — restrict reserved-account provisioning to a single partner bank
# code (e.g. Moniepoint MFB's code). Unset requests every partner bank
# Monnify supports and surfaces the first one returned.
MONNIFY_RESERVED_ACCOUNT_BANK_CODE=
# Rollout flag for the real Paycode API (offline payout — hosts cash out at
# a Moniepoint POS agent). Defaults to false — PaycodeService keeps
# fabricating a mock paycode until this is set to true after a sandbox
# smoke test.
MONNIFY_USE_PAYCODE_API=false
# Hours a freshly-created paycode stays redeemable before the background
# sweep (every 5 minutes) auto-expires it and credits the wallet back.
MONNIFY_PAYCODE_EXPIRY_HOURS=24

# ── Platform ──────────────────────────────────────────────────
# Cut from each successful booking payment, in basis points (250 = 2.5%)
PLATFORM_FEE_BPS=250

# ── Mail ──────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=*******
SMTP_PASS==*******
SMTP_SECURE=false
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME="Bookmi by Qorelly"

# ── Frontend URL ─────────────────────────────────────────────
# Where the SPA lives — used when we build the OTP verify link that goes
# into the "Confirm email" / "Reset password" emails. Point this at your
# deployed frontend in prod (e.g. https://bookmi.co).
WEB_BASE_URL=http://localhost:5173

# ── Redis (BullMQ email queue) ───────────────────────────────
# Bookmi uses BullMQ to enqueue emails so an SMTP hiccup doesn't unwind
# whatever domain action produced the email. Set REDIS_HOST + REDIS_PORT
# for a native install, or `docker compose -f docker/docker-compose.yml
# up -d redis` for the containerized version.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_QUEUE_DB=1

# ── Bull Board admin UI (optional) ───────────────────────────
# When both are set, `/api/admin/queues` shows a live view of email jobs +
# retries + failures, protected by HTTP Basic Auth. Leave empty to disable.
BULL_BOARD_USER=
BULL_BOARD_PASS=