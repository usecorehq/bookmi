NODE_ENV=development
APP_ENV=dev
PORT=4000

# ── Supabase ──────────────────────────────────────────────────
# Local self-hosted: http://localhost:8000
# Cloud:            https://<project-ref>.supabase.co
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# HS256 secret from Supabase → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=

# Postgres connection.
# Local:            postgres://postgres:<pw>@localhost:54322/postgres
# Cloud (direct):   postgres://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
# Cloud (pooled):   postgres://postgres.<ref>:<pw>@<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ── Monnify ───────────────────────────────────────────────────
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WEBHOOK_SECRET=

# ── Platform ──────────────────────────────────────────────────
# Cut from each successful booking payment, in basis points (250 = 2.5%)
PLATFORM_FEE_BPS=250

# ── Mail ──────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=*******
SMTP_PASS==*******
SMTP_SECURE=false
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME="Bookmi by Qorelly"