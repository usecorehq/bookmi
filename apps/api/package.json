{
  "name": "@bookmi/api",
  "version": "0.0.1",
  "private": true,
  "description": "Bookmi backend — payments, bookings, wallets, payouts.",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --selectProjects unit",
    "test:int": "NODE_OPTIONS=--experimental-vm-modules jest --selectProjects integration --runInBand",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --config test/e2e/jest-e2e.config.js",
    "test": "pnpm test:unit && pnpm test:int && pnpm test:e2e",
    "clean": "rm -rf dist .turbo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "email:dev": "email dev --dir src/modules/emails/templates --port 3010"
  },
  "dependencies": {
    "@bookmi/shared-types": "workspace:*",
    "@nestjs-modules/mailer": "^2.3.7",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.6",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "@supabase/supabase-js": "^2.47.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "drizzle-orm": "^0.38.3",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "nestjs-zod": "^5.4.0",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@bookmi/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@react-email/ui": "^6.9.0",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.1",
    "jest": "^29.7.0",
    "react-email": "^6.9.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2"
  }
}
