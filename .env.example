# ────────────────────────────────────────────────
# Bookmi — root .env.example
# Copy relevant blocks into apps/api/.env and apps/web/.env
# ────────────────────────────────────────────────

# ── Supabase (both apps) ───────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# HS256 secret from Supabase → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=

# ── Postgres direct (backend / drizzle) ────────
# Local:            postgres://postgres:<pw>@localhost:54322/postgres
# Cloud (direct):   postgres://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
# Cloud (pooled):   postgres://postgres.<ref>:<pw>@<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ── Monnify (backend) ──────────────────────────
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WEBHOOK_SECRET=

# ── Platform ───────────────────────────────────
# Fee taken from each successful booking, in basis points (250 = 2.5%)
PLATFORM_FEE_BPS=250
PORT=4000

# ── Web (Vite, must be prefixed VITE_) ─────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:4000
VITE_MONNIFY_API_KEY=
VITE_MONNIFY_CONTRACT_CODE=
