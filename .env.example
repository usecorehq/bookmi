# ────────────────────────────────────────────────
# Bookmi — root .env.example
# Copy relevant blocks into apps/api/.env and apps/web/.env
# ────────────────────────────────────────────────

# ── Supabase (both apps) ───────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Postgres direct (backend / drizzle) ────────
# Get from Supabase → Project Settings → Database → Connection string (URI, pooled)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── Monnify (backend) ──────────────────────────
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WEBHOOK_SECRET=

# ── Platform ───────────────────────────────────
# Fee taken from each successful booking, in basis points (250 = 2.5%)
PLATFORM_FEE_BPS=250
PORT=4000

# ── Web (Vite, must be prefixed VITE_) ─────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:4000
VITE_MONNIFY_API_KEY=
VITE_MONNIFY_CONTRACT_CODE=
